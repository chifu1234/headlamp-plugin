# Minimize Docker context transfer (the final image only contains what is COPYed).
# We deliberately do NOT ignore dist/ or package.json because the Dockerfile needs them.
node_modules/
src/
.git/
.github/
*.tar.gz
*.log
.eslintcache
eslint.config.js.bak
README.md
artifacthub-pkg.yml
package-lock.json
